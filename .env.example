# Meta (Facebook) Ads API — campaign optimization
# Obtain a long-lived System User access token from business.facebook.com with
# ads_management + ads_read scopes.
META_ACCESS_TOKEN=
META_APP_ID=2411227719300403
META_AD_ACCOUNT_ID=act_2259508744311442
META_GRAPH_API_VERSION=v19.0

# Optional — pin a single campaign ID to optimize by default (e.g. the
# "Company Drivers - Traffic - AprXXXX" campaign). Leave blank to show all.
META_DEFAULT_CAMPAIGN_ID=
